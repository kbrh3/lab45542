# Frontend → Backend connection (REQUIRED)
BACKEND_URL=http://localhost:8000
BACKEND_API_KEY=your-secret-key-here

# Agent / model configuration (OPTIONAL)
GEMINI_API_KEY=your-gemini-api-key
MODEL_MODE=default
ENABLE_ERAG_EVAL=false
# Snowflake configuration (OPTIONAL)
# Note: Snowflake may use a programmatic access token instead of a password
USE_SNOWFLAKE=false
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password_or_programmatic_token
SNOWFLAKE_WAREHOUSE=LAB_5_PIPELINE
SNOWFLAKE_DATABASE=POLICYPULSE_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=your_role
