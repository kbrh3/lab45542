# Example Environment Configuration
# Copy this file to .env and replace the placeholder values with your actual secrets.
# Do NOT commit your actual .env file.

# Required for Streamlit Frontend & FastAPI Backend communication
BACKEND_URL=http://localhost:8000
BACKEND_API_KEY=your-secret-key-here

# Optional: Required only for Agent Mode
GEMINI_API_KEY=your-gemini-api-key

# Model mode: "baseline" or "adapted" (uses LoRA fine-tuned model)
MODEL_MODE=adapted

# Required for Snowflake Database Connection (Used by Agent Mode)
USE_SNOWFLAKE=false
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=LAB_5_PIPELINE
SNOWFLAKE_DATABASE=POLICYPULSE_DB
SNOWFLAKE_SCHEMA=PUBLIC
